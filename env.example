# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel
MODERATOR_CHAT_ID=your_telegram_id
PORT=10000

# Gemini — новий ключ: лише flash-моделі для текстових постів.
# НЕ додавай pro/image/tts/embedding/live — вони палять квоту або дають 403.
GEMINI_API_KEY=your_gemini_key
# 3.5-flash часто 503/таймаут — краще flash-latest як запасний.
GEMINI_MODELS=gemini-2.0-flash,gemini-flash-latest
# Альтернатива: gemini-2.0-flash,gemini-3.5-flash
# GEMINI_MAX_MODELS_PER_REQUEST=2
# Пауза між Gemini-запитами (сек) і макс. очікування Retry-After:
# GEMINI_MIN_INTERVAL_SEC=6
# GEMINI_MAX_RETRY_WAIT_SEC=180
# Глобальна пауза після вичерпання квоти (сек, Redis):
# GEMINI_GLOBAL_COOLDOWN_SEC=14400
# Повтори рубрики при 429 у розкладі:
# GEMINI_SCHEDULE_RETRIES=2
# GEMINI_SCHEDULE_RETRY_DELAY_SEC=180

# Upstash Redis
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your_redis_token

# YouTube
YOUTUBE_API_KEY=your_youtube_key

# NewsAPI
NEWSAPI_KEY=your_newsapi_key

# Stock photos
PEXELS_API_KEY=your_pexels_api_key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
STOCK_PHOTO_PROVIDER=auto
